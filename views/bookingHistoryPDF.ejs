<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking History Report</title>
    <style>
        /* General Reset */
        body, h1, h2, table, th, td {
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Roboto', Arial, sans-serif;
            background-color: #f9f9f9;
            color: #333;
            padding: 30px;
            line-height: 1.6;
        }

        h1 {
            text-align: center;
            font-size: 2.5rem;
            color: #fff;
            background: linear-gradient(135deg, #6a1b9a, #ff7043);
            padding: 15px 30px;
            border-radius: 6px;
            margin-bottom: 30px;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
        }

        h2 {
            font-size: 2rem;
            color: #333;
            margin-bottom: 20px;
            text-align: center;
            font-weight: 600;
            background-color: #ff7043;
            padding: 12px;
            color: #fff;
            border-radius: 8px;
            width: fit-content;
            margin-left: auto;
            margin-right: auto;
        }

        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
            border-radius: 8px;
            overflow: hidden;
            background-color: #fff;
            box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.1);
        }

        th, td {
            padding: 16px;
            text-align: left;
        }

        th {
            background-color: #6a1b9a;
            color: #fff;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        td {
            color: #555;
            font-size: 1rem;
        }

        td:nth-child(5), td:nth-child(6) {
            font-weight: bold;
        }

        td:nth-child(5) {
            color: #1976d2;
        }

        td:nth-child(6) {
            color: #388e3c;
        }

        tr:nth-child(even) {
            background-color: #f4f4f4;
        }

        tr:hover {
            background-color: #f1f1f1;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            body {
                padding: 20px;
            }

            h1 {
                font-size: 2rem;
                padding: 12px 20px;
            }

            h2 {
                font-size: 1.5rem;
                margin-top: 20px;
            }

            table {
                margin-top: 15px;
            }

            th, td {
                padding: 10px;
                font-size: 0.9rem;
            }
        }

        /* Optional: Add nice page break for PDF */
        @media print {
            body {
                padding: 10px;
            }

            h1, h2 {
                page-break-after: avoid;
            }

            table {
                page-break-inside: auto;
            }
        }
    </style>
</head>
<body>
    <h1>Ocean Breeze</h1>
    <h2>Booking History Report</h2>
    <table>
        <thead>
            <tr>
                <th>Booking ID</th>
                <th>Guest</th>
                <th>Room</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% bookings.forEach(booking => { %>
                <tr>
                    <td><%= booking._id.toString().slice(-6) %></td>
                    <td><%= booking.guest.name %></td>
                    <td><%= booking.roomNumber %></td>
                    <td><%= booking.checkInDate.toISOString().split('T')[0] %></td>
                    <td><%= booking.checkOutDate.toISOString().split('T')[0] %></td>
                    <td><%= booking.status %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>
