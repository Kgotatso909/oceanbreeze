<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking History Report</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
            background-color: #f7f7f7;
            color: #333;
        }

        h1 {
            text-align: center;
            font-size: 3rem;
            color: #fff;
            background: linear-gradient(45deg, #ff6b6b, #f0a500);
            display: inline-block;
            padding: 20px;
            position: relative;
            border-radius: 8px;
        }

        h1::before, h1::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 5px;
            background-color: #fff;
            left: 0;
            bottom: -10px;
            border-radius: 5px;
        }

        h1::after {
            top: -10px;
            bottom: auto;
        }

        h2 {
            font-size: 2rem;
            color: #333;
            margin-top: 40px;
            text-align: center;
            font-weight: bold;
            background-color: #ff6b6b;
            padding: 10px;
            color: white;
            border-radius: 5px;
            width: fit-content;
            margin-left: auto;
            margin-right: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background-color: #fff;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            overflow: hidden;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: left;
        }

        th {
            background-color: #ff6b6b;
            color: #fff;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        tr:hover {
            background-color: #f0f0f0;
        }

        td {
            color: #555;
        }

        td:nth-child(5) {
            color: #007bff;
        }

        td:nth-child(6) {
            font-weight: bold;
            color: #28a745;
        }

        /* Responsive design for smaller screens */
        @media (max-width: 768px) {
            body {
                padding: 10px;
            }
            
            h1 {
                font-size: 2.5rem;
                padding: 15px;
            }

            h2 {
                font-size: 1.5rem;
                margin-top: 30px;
            }

            table {
                margin-top: 10px;
            }

            th, td {
                padding: 8px;
            }
        }
    </style>
</head>
<body>
    <h1>Ocean Breeze</h1>
    <h2>Booking History Report</h2>
    <table>
        <thead>
            <tr>
                <th>Booking ID</th>
                <th>Guest</th>
                <th>Room</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% bookings.forEach(booking => { %>
                <tr>
                    <td><%= booking._id.toString().slice(-6) %></td>
                    <td><%= booking.guest.name %></td>
                    <td><%= booking.roomNumber %></td>
                    <td><%= booking.checkInDate.toISOString().split('T')[0] %></td>
                    <td><%= booking.checkOutDate.toISOString().split('T')[0] %></td>
                    <td><%= booking.status %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>
