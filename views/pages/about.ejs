<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"  />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fancybox/3.5.7/jquery.fancybox.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/8.1.6/swiper-bundle.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <link rel="stylesheet" href="css/styles.css">
    <style  nonce="<%= nonce %>">
        /* General Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth; 
}

body {
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    color: #000;
    background: #fff;
}

.section-title {
    position: relative;
    text-align: center;
    margin-bottom: 40px;  /* Space between title and grid */
    padding: 0 20px; /* Add padding for better spacing on small devices */
}

.section-title  {
    font-size: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #fff;
    position: relative;
    margin: 0;
    padding: 0;
}

/* Before and After Effects for Section Title */
.section-title::before,
.section-title::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 20%;
    height: 1px;
    background-color: #333;
    transform: translateY(-50%);
}

.section-title::before {
    left: 0;
}

.section-title::after {
    right: 0;
}

/* Optional decorative flair */
.section-title::before {
    background-image: linear-gradient(45deg, #ff7e5f, #feb47b);
    background-size: 100% 2px;
}

.section-title::after {
    background-image: linear-gradient(45deg, #ff7e5f, #feb47b);
    background-size: 100% 2px;
}

/* Make the title lines responsive */
@media (max-width: 768px) {
    .section-title {
        font-size: 1.5rem;  /* Smaller font size for mobile */
    }

    .section-title::before,
    .section-title::after {
        width: 15%;  /* Shorten the lines for smaller screens */
    }
}

img {
  object-fit: cover;
}

.toast {
    max-width: 400px;
    opacity: 0.9;
    font-size: 1rem;
    background-color: #28a745;
    color: white;
}

.toast-header {
    background-color: #218838;
}

.toast-body {
    background-color: #28a745;
}

.toast-body small {
    color: #fff;
}

/* navigation */
.sticky-navbar {
    position: sticky;
    top: 0;
    z-index: 999;
    width: 100%;
    background: rgba(32, 31, 31, 0.932);
}


.navbar {
    width: 100%;
    z-index: 998; 
    padding: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
}

.navbar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: rgba(32, 31, 31, 0.932);
}

.navbar .logo a {
    font-size: 32px;
    color: white;
    font-weight: bold;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
}

.navbar-menu ul {
    list-style: none;
    display: flex;
    gap: 30px;
}

.navbar-menu a {
    color: white;
    font-size: 18px;
    text-decoration: none;
    text-transform: uppercase;
    transition: 0.3s ease;
    position: relative;
}

.navbar-menu a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(45deg, #ff0080, #ff8c00);
    transition: 0.3s ease;
    transform: translateX(-50%);
}

.navbar-menu a:hover::after {
    width: 100%;
}


.sidebar {
    position: fixed;
    top: 0;
    left: -300px;
    height: 100%;
    width: 300px;
    background: linear-gradient(135deg, #130f0f, #161616);
    transition: left 0.3s ease;
    z-index: 9999;
}

.sidebar.open {
    left: 0;
}

.sidebar-content {
    padding: 50px 20px;
}

.sidebar-content h3 {
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.sidebar ul {
    list-style: none;
    padding: 0;
}

.sidebar ul li {
    padding: 15px 0;
    border-bottom: 1px solid #fff;
}

.sidebar ul li a {
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
    transition: color 0.3s ease;
}

.sidebar ul li a:hover {
    color: #000;
}

#sidebar-close {
    position: absolute;
    top: 20px;
    right: 20px;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    z-index: 9999;
}

#hamburger-toggle {
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    padding: 10px;
    cursor: pointer;
    display: none;
}

@media (max-width: 768px) {
    .navbar-menu {
        display: none;
    }

    #hamburger-toggle {
        display: block;
    }

    .sidebar.open {
        left: 0;
    }

    body, html {
        overflow-x: hidden;
    }
}


/* About Hero Section */
.about-hero {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400px; /* Suitable height for About section */
  width: 100%; /* Full width */
  background: url('images/hero-3.jpg') no-repeat center center/cover; /* Image background */
  position: relative;
  text-align: center;
  overflow: hidden;
  color: white;
}

/* Background gradient overlay */
.about-hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.4));
  z-index: 1;
}

/* Content inside the hero section */
.about-hero-content {
  position: relative;
  z-index: 2;
  color: white;
  padding: 20px;
  text-align: center;
}

/* Title */
.about-title {
  font-size: 3.5rem; /* Large title */
  font-weight: bold;
  letter-spacing: 1px;
  margin-bottom: 15px;
  text-transform: uppercase;
  animation: fadeInUp 1s ease-out;
}

/* Description */
.about-description {
  font-size: 1.2rem;
  max-width: 80%;
  margin: 0 auto;
  line-height: 1.6;
  letter-spacing: 0.5px;
  opacity: 0.85;
  margin-bottom: 25px;
  animation: fadeInUp 1.5s ease-out;
}

/* Call to Action Button */
.about-cta {
  display: inline-block;
  padding: 15px 30px;
  font-size: 1rem;
  font-weight: bold;
  text-transform: uppercase;
  border: 2px solid #fff;
  background-color: transparent;
  color: #fff;
  text-decoration: none;
  letter-spacing: 1px;
  border-radius: 30px;
  transition: background-color 0.3s ease;
}

/* Hover effect on CTA */
.about-cta:hover {
  background-color: #fff;
  color: #333;
}

/* Fade-in animation for elements */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Full width and height for the body */
html, body {
  width: 100%;
  height: 100%;
  overflow-x: hidden;
  margin: 0;
}






    </style>
</head>
<body>
    <%- include("../partials/_nav.ejs") %>
    <section class="about-hero">
        <div class="about-hero-content">
          <h1 class="about-title">Who We Are</h1>
          <p class="about-description">Learn more about our journey, mission, and the values that drive us to provide exceptional service.</p>
          <a href="/booking" class="about-cta">Book Now</a>
        </div>
      </section>

       <!-- About Page -->
       <section id="about" class="about-section">
        <div class="about-container container">
          <!-- Left Column (Text and Details) -->
          <div class="about-left">
            <h2 class="section-title-icon">
              <i class="fa-regular fa-star"></i>
              <i class="fa-regular fa-star"></i>
              About Ocean Breeze
              <i class="fa-regular fa-star"></i>
              <i class="fa-regular fa-star"></i>
            </h2>
            <p>
              At Ocean Breeze, we provide a cozy and comfortable stay for travelers. Whether you're here for business, leisure, or a special event, we offer top-notch facilities and services to make your experience unforgettable.
            </p>
      
            <div class="about-tabs">
              <button class="tab-button active" data-tab="mission">Our Mission</button>
              <button class="tab-button" data-tab="offerings">What We Offer</button>
              <button class="tab-button" data-tab="location">Location</button>
            </div>
      
            <div class="tab-content" id="mission">
              <p>Our goal is to create a welcoming environment where guests can relax, unwind, and feel at home. We are committed to providing high-quality service, clean accommodations, and an unforgettable experience for every guest that walks through our doors.</p>
            </div>
            <div class="tab-content" id="offerings">
              <p>At Ocean Breeze, we offer more than just a place to stay. Our guesthouse is designed with your comfort in mind, featuring spacious rooms with modern amenities, a range of personalized services, and a friendly team committed to ensuring your stay is as pleasant as possible.</p>
            </div>
            <div class="tab-content" id="location">
              <p>Located in the heart of the city, our guesthouse is just minutes away from popular attractions, restaurants, and public transport. Perfect for both business and leisure travelers.</p>
            </div>
          </div>
      
          <!-- Right Column (Images) -->
          <div class="about-right">
            <div class="about-image">
              <img src="images/hero-1.jpg" alt="Guesthouse Exterior">
              <p>Our beautiful guesthouse exterior.</p>
            </div>
            <div class="about-image">
              <img src="images/hero-1.jpg" alt="Room Interior">
              <p>Comfortable, modern rooms designed for your relaxation.</p>
            </div>
          </div>
        </div>
      </section>
      
    
<section id="about-us" class="about-us-section px-4 pb-5">
  <div class="container">
    <div class="row mt-5">
      <div class="col-md-6">
        <h2>Why Stay With Us?</h2>
        <p>
          Golden Fields offers the perfect blend of comfort and convenience, with personalized service, stunning views, and a relaxing environment. Here’s why guests choose us:
        </p>
        <div class="accordion" id="why-stay">
          <div class="accordion-item">
            <h2 class="accordion-header" id="headingOne">
              <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                Peaceful & Scenic Location
              </button>
            </h2>
            <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#why-stay">
              <div class="accordion-body">
                Our guest house is located in the heart of nature, offering a tranquil escape from the hustle and bustle of everyday life. Wake up to the sounds of birds chirping and enjoy scenic views right from your room.
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="headingTwo">
              <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                Affordable Luxury
              </button>
            </h2>
            <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#why-stay">
              <div class="accordion-body">
                Our rates are designed to provide luxurious accommodations at affordable prices. We believe in offering value for money while maintaining high standards of service and comfort.
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="headingThree">
              <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                Family-Friendly & Safe
              </button>
            </h2>
            <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#why-stay">
              <div class="accordion-body">
                Our guest house is perfect for families, offering spacious rooms and facilities designed with families in mind. We also prioritize safety and security, ensuring peace of mind for you and your loved ones.
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <h2>Room Pricing</h2>
        <p>We offer competitive pricing for our various room types. Below are our room rates:</p>
        <ul>
          <% rooms.forEach(room => { %>
            <li><%= room.roomType %>: <strong>R<%= room.price %>/night</strong></li>
          <% }); %>
        </ul>
        <button class="btn btn-primary mt-4" data-bs-toggle="collapse" data-bs-target="#pricingDetails" aria-expanded="false" aria-controls="pricingDetails">
          View More Pricing Details
        </button>
        <div class="collapse mt-3" id="pricingDetails">
          <ul>
            <li>Special discounts available for extended stays.</li>
            <li>Prices include complimentary breakfast.</li>
            <li>Discounts for group bookings and events.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
 
</section>
  
    <%- include("../partials/_footer.ejs") %>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fancybox/3.5.7/jquery.fancybox.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/8.1.6/swiper-bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/paroller.js/1.4.7/jquery.paroller.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script src="js/flatpickr.js"></script>
    <script src="js/paroller.js"></script>
    <script src="js/swiper.js"></script>
    <script src="js/main.js"></script>
    <script nonce="<%= nonce %>">
      document.addEventListener("DOMContentLoaded", ()=>{
         // Add event listeners to tab buttons
  const buttons = document.querySelectorAll('.tab-button');
  buttons.forEach(button => {
    button.addEventListener('click', function () {
      const tabId = button.getAttribute('data-tab');
      showTab(tabId);
    });
                // Set the default tab to "mission"
  showTab('mission');

  });

      })
       function showTab(tabId) {
    // Hide all tab content
    const contents = document.querySelectorAll('.tab-content');
    contents.forEach(content => {
      content.style.display = 'none';
    });
  
    // Remove the active class from all buttons
    const buttons = document.querySelectorAll('.tab-button');
    buttons.forEach(button => {
      button.classList.remove('active');
    });
  
    // Show the selected tab and add active class to the clicked button
    document.getElementById(tabId).style.display = 'block';
    document.querySelector(`[data-tab="${tabId}"]`).classList.add('active');
  }
    </script>
</body>
</html>