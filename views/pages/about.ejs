    <style  nonce="<%= nonce %>">
        /* General Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth; 
}

body {
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    color: #000;
    background: #fff;
}

.section-title {
    position: relative;
    text-align: center;
    margin-bottom: 40px;  /* Space between title and grid */
    padding: 0 20px; /* Add padding for better spacing on small devices */
}

.section-title  {
    font-size: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #fff;
    position: relative;
    margin: 0;
    padding: 0;
}

/* Before and After Effects for Section Title */
.section-title::before,
.section-title::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 20%;
    height: 1px;
    background-color: #333;
    transform: translateY(-50%);
}

.section-title::before {
    left: 0;
}

.section-title::after {
    right: 0;
}

/* Optional decorative flair */
.section-title::before {
    background-image: linear-gradient(45deg, #ff7e5f, #feb47b);
    background-size: 100% 2px;
}

.section-title::after {
    background-image: linear-gradient(45deg, #ff7e5f, #feb47b);
    background-size: 100% 2px;
}

/* Make the title lines responsive */
@media (max-width: 768px) {
    .section-title {
        font-size: 1.5rem;  /* Smaller font size for mobile */
    }

    .section-title::before,
    .section-title::after {
        width: 15%;  /* Shorten the lines for smaller screens */
    }
}

img {
  object-fit: cover;
}

.toast {
    max-width: 400px;
    opacity: 0.9;
    font-size: 1rem;
    background-color: #28a745;
    color: white;
}

.toast-header {
    background-color: #218838;
}

.toast-body {
    background-color: #28a745;
}

.toast-body small {
    color: #fff;
}

/* navigation */
.sticky-navbar {
    position: sticky;
    top: 0;
    z-index: 999;
    width: 100%;
    background: rgba(32, 31, 31, 0.932);
}


.navbar {
    width: 100%;
    z-index: 998; 
    padding: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
}

.navbar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: rgba(32, 31, 31, 0.932);
}

.navbar .logo a {
    font-size: 32px;
    color: white;
    font-weight: bold;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
}

.navbar-menu ul {
    list-style: none;
    display: flex;
    gap: 30px;
}

.navbar-menu a {
    color: white;
    font-size: 18px;
    text-decoration: none;
    text-transform: uppercase;
    transition: 0.3s ease;
    position: relative;
}

.navbar-menu a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(45deg, #ff0080, #ff8c00);
    transition: 0.3s ease;
    transform: translateX(-50%);
}

.navbar-menu a:hover::after {
    width: 100%;
}


.sidebar {
    position: fixed;
    top: 0;
    left: -300px;
    height: 100%;
    width: 300px;
    background: linear-gradient(135deg, #130f0f, #161616);
    transition: left 0.3s ease;
    z-index: 9999;
}

.sidebar.open {
    left: 0;
}

.sidebar-content {
    padding: 50px 20px;
}

.sidebar-content h3 {
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.sidebar ul {
    list-style: none;
    padding: 0;
}

.sidebar ul li {
    padding: 15px 0;
    border-bottom: 1px solid #fff;
}

.sidebar ul li a {
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
    transition: color 0.3s ease;
}

.sidebar ul li a:hover {
    color: #000;
}

#sidebar-close {
    position: absolute;
    top: 20px;
    right: 20px;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    z-index: 9999;
}

#hamburger-toggle {
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    padding: 10px;
    cursor: pointer;
    display: none;
}

@media (max-width: 768px) {
    .navbar-menu {
        display: none;
    }

    #hamburger-toggle {
        display: block;
    }

    .sidebar.open {
        left: 0;
    }

    body, html {
        overflow-x: hidden;
    }
}


/* About Hero Section */
.about-hero {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400px; /* Suitable height for About section */
  width: 100%; /* Full width */
  background: url('images/hero-3.jpg') no-repeat center center/cover; /* Image background */
  position: relative;
  text-align: center;
  overflow: hidden;
  color: white;
}

/* Background gradient overlay */
.about-hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.4));
  z-index: 1;
}

/* Content inside the hero section */
.about-hero-content {
  position: relative;
  z-index: 2;
  color: white;
  padding: 20px;
  text-align: center;
}

/* Title */
.about-title {
  font-size: 3.5rem; /* Large title */
  font-weight: bold;
  letter-spacing: 1px;
  margin-bottom: 15px;
  text-transform: uppercase;
  animation: fadeInUp 1s ease-out;
}

/* Description */
.about-description {
  font-size: 1.2rem;
  max-width: 80%;
  margin: 0 auto;
  line-height: 1.6;
  letter-spacing: 0.5px;
  opacity: 0.85;
  margin-bottom: 25px;
  animation: fadeInUp 1.5s ease-out;
}

/* Call to Action Button */
.about-cta {
  display: inline-block;
  padding: 15px 30px;
  font-size: 1rem;
  font-weight: bold;
  text-transform: uppercase;
  border: 2px solid #fff;
  background-color: transparent;
  color: #fff;
  text-decoration: none;
  letter-spacing: 1px;
  border-radius: 30px;
  transition: background-color 0.3s ease;
}

/* Hover effect on CTA */
.about-cta:hover {
  background-color: #fff;
  color: #333;
}

/* Fade-in animation for elements */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Full width and height for the body */
html, body {
  width: 100%;
  height: 100%;
  overflow-x: hidden;
  margin: 0;
}

    </style>
</head>
