<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-5">

    <h1 class="mb-4">Admin Dashboard</h1>

    <div>
        <h2>Quick Access</h2>
        <ul>
            <li><a href="/admin/manageRooms">Manage Rooms</a></li>
            <!-- You can add more links here for booking management, etc. -->
            <li><a href="/admin/manage-bookings">Manage Bookings</a></li>
            <li><a href="/admin/settings">Settings</a></li>
        </ul>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-header">Total Bookings</div>
                <div class="card-body">
                    <h5 class="card-title"><%= totalBookings %></h5>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-header">Total Revenue</div>
                <div class="card-body">
                    <h5 class="card-title">$<%= totalRevenue %></h5>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3">
                <div class="card-header">Available Rooms</div>
                <div class="card-body">
                    <h5 class="card-title"><%= availableRooms %></h5>
                </div>
            </div>
        </div>
    </div>

    <h2 class="mt-4">Pending Bookings</h2>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Room</th>
                <th>Guest Name</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% bookings.forEach(booking => { %>
                <tr>
                    <td><%= booking.roomNumber %></td>
                    <td><%= booking.guest.name %></td>
                    <td><%= booking.checkInDate.toDateString() %></td>
                    <td><%= booking.checkOutDate.toDateString() %></td>
                    <td>
                        <form action="/admin/update-booking/<%= booking._id %>" method="POST">
                            <button type="submit" class="btn btn-success btn-sm">update</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

</body>
</html>

