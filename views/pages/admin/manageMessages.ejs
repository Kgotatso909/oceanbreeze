<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Messages</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="../css/admin.css">
</head>
<body>
     <!-- Side bar  -->
     <%- include("../../partials/admin/_nav.ejs") %>

     <div class="content container mt-4">
        <h2 class="mb-4 text-center">Manage Messages</h2>

        <!-- Filter Dropdown -->
        <form action="/admin/messages" method="GET" class="d-flex align-items-center gap-2 mb-3">
            <label for="filter" class="fw-bold me-2">Filter by status:</label>
            <select name="filter" id="filter" class="form-select w-auto">
                <option value="">All</option>
                <option value="pending" <%= filter === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="replied" <%= filter === 'replied' ? 'selected' : '' %>>Replied</option>
            </select>
        </form>

        <!-- Messages Table -->
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Subject</th>
                        <th>Message</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% messages.forEach(message => { %>
                    <tr>
                        <td><%= message.username %></td>
                        <td><%= message.email %></td>
                        <td><%= message.subject %></td>
                        <td class="text-truncate" style="max-width: 200px;"><%= message.message %></td>
                        <td>
                            <span class="badge <%= message.respond === 'pending' ? 'bg-warning' : 'bg-success' %>">
                                <%= message.respond %>
                            </span>
                        </td>
                        <td>
                            <% if (message.respond === 'pending') { %>
                                <form action="/admin/messages/reply" method="POST">
                                    <input type="hidden" name="messageId" value="<%= message._id %>">
                                    <button type="submit" class="btn btn-sm btn-primary">Mark as Replied</button>
                                </form>
                            <% } else { %>
                                <span class="text-muted">No Action</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
    <script nonce="<%= nonce %>">
        document.addEventListener('DOMContentLoaded', function() {
            const filterSelect = document.getElementById('filter');
            filterSelect.addEventListener('change', function() {
                this.form.submit();
            });
        });
    </script>    
</body>
</html>

