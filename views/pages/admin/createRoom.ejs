<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Create Room</title>
</head>
<body>
    <h1>Create New Room</h1>
    <form action="/admin/createRoom" method="POST">
        <label for="roomNumber">Room Number:</label>
        <input type="number" id="roomNumber" name="roomNumber" required><br><br>

        <label for="capacity">Capacity:</label>
        <input type="number" id="capacity" name="capacity" required><br><br>

        <label for="price">Price:</label>
        <input type="number" id="price" name="price" required><br><br>

        <label for="available">Available:</label>
        <input type="checkbox" id="available" name="available"><br><br>

        <button type="submit">Create Room</button>
    </form>
</body>
</html>
