
<h1>Manage Bookings</h1>

<table class="table">
    <thead>
        <tr>
            <th>Room</th>
            <th>Guest Name</th>
            <th>Check-in</th>
            <th>Check-out</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% bookings.forEach(booking => { %>
            <tr>
                <td><%= booking.roomNumber %></td>
                <td><%= booking.guest.name %></td>
                <td><%= booking.checkInDate.toDateString() %></td>
                <td><%= booking.checkOutDate.toDateString() %></td>
                <td><%= booking.status %></td>
                <td>
                    <% if (booking.status === 'pending' || booking.status === 'approved') { %>
                        <a href="/admin/update-booking/<%= booking._id %>">Update</a>
                    <% } %>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>


<div>
    <h2>Export Booking History</h2>
    <a href="/admin/export-booking-history" class="btn btn-success">Download CSV</a>
    <a href="/admin/export-booking-history-pdf" class="btn btn-danger">Download PDF</a>
</div>
