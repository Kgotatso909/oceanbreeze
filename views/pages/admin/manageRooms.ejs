<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Rooms</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="../css/admin.css">
    <style nonce="<%= nonce %>">
         .table {
            margin-top: 20px;
        }
    </style>
</head>
<body>
     <!-- Side bar  -->
     <%- include("../../partials/admin/_nav.ejs") %>

    <div class="content">
        <h1 class="mb-4">Manage Rooms</h1>
        <a href="/admin/createRoom" class="btn btn-primary mb-3">Create New Room</a>
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Room Number</th>
                    <th>Capacity</th>
                    <th>Price</th>
                    <th>Available</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% rooms.forEach(room => { %>
                    <tr>
                        <td><%= room.roomNumber %></td>
                        <td><%= room.capacity %></td>
                        <td><%= room.price %></td>
                        <td><%= room.available ? 'Yes' : 'No' %></td>
                        <td>
                            <a href="/admin/editRoom/<%= room._id %>" class="btn btn-warning btn-sm">Edit</a>
                            <form action="/admin/deleteRoom/<%= room._id %>" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

</body>
</html>
