<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Send Newsletter</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="../css/admin.css">
</head>
<body>
    <!-- Sidebar -->
    <%- include("../../partials/admin/_nav.ejs") %>

    <div class="content container mt-4">
        <div class="card p-4 shadow-lg">
            <h2 class="mb-4 text-center">Send Newsletter</h2>

            <form action="/admin/send-newsletter" method="POST">
                <!-- Subject -->
                <div class="mb-3">
                    <label for="subject" class="form-label">Newsletter Subject:</label>
                    <input type="text" class="form-control" name="subject" placeholder="Enter subject" required>
                </div>

                <!-- Message -->
                <div class="mb-3">
                    <label for="message" class="form-label">Newsletter Message:</label>
                    <textarea class="form-control" name="message" rows="5" placeholder="Enter message" required></textarea>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary w-100">Send Newsletter</button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
