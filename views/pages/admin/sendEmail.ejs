<!DOCTYPE html>
<html>
<head>
    <title>Send Email</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="../css/admin.css">
    <style nonce="<%= nonce %>">
       #promoFields {
        display: none;
       } 
    </style>
</head>
<body>
     <!-- Side bar  -->
     <%- include("../../partials/admin/_nav.ejs") %>

     <div class="content container mt-4">
        <h2 class="mb-4 text-center">Send Email to Subscribers</h2>

        <form action="/admin/send-email" method="POST" class="card p-4 shadow-lg">
            <!-- Recipient Email -->
            <div class="mb-3">
                <label for="recipientEmail" class="form-label">Recipient Email:</label>
                <input type="email" class="form-control" name="recipientEmail" required>
            </div>

            <!-- Subject -->
            <div class="mb-3">
                <label for="subject" class="form-label">Subject:</label>
                <input type="text" class="form-control" name="subject" required>
            </div>

            <!-- Template Selection -->
            <div class="mb-3">
                <label for="template" class="form-label">Select Template:</label>
                <select name="template" class="form-select" required>
                    <option value="welcome">Welcome Email</option>
                    <option value="promotion">Promotional Offer</option>
                    <option value="custom">Custom Message</option>
                </select>
            </div>

            <!-- Recipient Name -->
            <div class="mb-3">
                <label for="name" class="form-label">Recipient Name:</label>
                <input type="text" class="form-control" name="name" required>
            </div>

            <!-- Promotion Fields (Hidden by Default) -->
            <div id="promoFields" class="border rounded p-3 mb-3 bg-light" ">
                <h5 class="text-primary">Promotion Details</h5>
                <div class="mb-3">
                    <label for="discount" class="form-label">Discount (%):</label>
                    <input type="number" class="form-control" name="discount">
                </div>
                <div class="mb-3">
                    <label for="promoCode" class="form-label">Promo Code:</label>
                    <input type="text" class="form-control" name="promoCode">
                </div>
            </div>

            <!-- Message -->
            <div class="mb-3">
                <label for="message" class="form-label">Message:</label>
                <textarea class="form-control" name="message" rows="4"></textarea>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-primary w-100">Send Email</button>
        </form>
    </div>
    
    <script nonce="<%= nonce %>">
        document.querySelector('select[name="template"]').addEventListener('change', function() {
            document.getElementById('promoFields').style.display = this.value === 'promotion' ? 'block' : 'none';
        });
    </script>
</body>
</html>
