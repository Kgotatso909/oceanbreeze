<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet" href="css/styles.css">
    <title>Available Rooms</title>
    <style nonce="<%= nonce %>">

.date-info {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    color: #666;
    text-align: center;
}

.room-card {
    border-radius: 15px;
    overflow: hidden;
    transition: transform 0.3s ease-in-out;
}
.room-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
}
.room-image {
    height: 200px;
    object-fit: cover;
    border-top-left-radius: 15px;
    border-top-right-radius: 15px;
}
.price {
    color: #28a745;
    font-size: 1.2rem;
}

    </style>
</head>
<body>

  <div class="container mt-5">
    <h2 class="section-title text-black">Available Rooms</h2>
    <p class="date-info">Check-in: <%= checkInDate %> | Check-out: <%= checkOutDate %></p>
    <div class="container mt-5">
      <div class="row">
          <% if (availableRooms.length > 0) { %>
              <% availableRooms.forEach(room => { %>
                  <div class="col-md-6 col-lg-4 mb-4">
                      <div class="card shadow-sm border-0 room-card">
                          <div id="carousel<%= room.roomNumber %>" class="carousel slide" data-bs-ride="carousel">
                              <div class="carousel-inner">
                                  <% room.images.forEach((image, index) => { %>
                                      <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                                          <img src="<%= image %>" class="d-block w-100 room-image" alt="Room Image">
                                      </div>
                                  <% }) %>
                              </div>
                              <button class="carousel-control-prev" type="button" data-bs-target="#carousel<%= room.roomNumber %>" data-bs-slide="prev">
                                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                              </button>
                              <button class="carousel-control-next" type="button" data-bs-target="#carousel<%= room.roomNumber %>" data-bs-slide="next">
                                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                              </button>
                          </div>
                          <div class="card-body">
                              <h5 class="card-title">Room <%= room.roomNumber %></h5>
                              <p class="card-text"><i class="bi bi-people-fill"></i> Capacity: <%= room.capacity %> guests</p>
                              <p class="card-text price"><strong>R<%= room.price %></strong> per night</p>
                              <a href="/book-room?room=<%= room.roomNumber %>&checkIn=<%= checkInDate %>&checkOut=<%= checkOutDate %>" class="btn btn-primary w-100">Book Now</a>
                          </div>
                      </div>
                  </div>
              <% }) %>
          <% } else { %>
              <div class="col-12">
                  <p class="alert alert-warning text-center">No rooms available for the selected dates.</p>
              </div>
          <% } %>
      </div>
  </div>
  <a href="/" class="btn btn-primary">Go Back to Home</a>
  </div>

  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.min.js"></script>
</body>
</html>
